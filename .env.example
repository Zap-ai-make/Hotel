# Hotel Management System - Variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs

# Base de donnees Neon PostgreSQL
# Creer un projet sur https://neon.tech (tier gratuit)
# Utiliser l'URL avec -pooler pour l'application
DATABASE_URL="postgresql://user:password@endpoint-pooler.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth v5
# Generer avec: npx auth secret
AUTH_SECRET=""

# Environnement
NODE_ENV="development"
