// Hotel Management System - Schema Prisma
// Base de donnees: Neon PostgreSQL

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    RECEPTIONNISTE
    MANAGER
    ADMIN
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    nom       String
    password  String
    role      Role     @default(RECEPTIONNISTE)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([email])
}
