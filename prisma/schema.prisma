// Hotel Management System - Schema Prisma
// Base de donnees: Neon PostgreSQL

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    RECEPTIONNISTE
    MANAGER
    ADMIN
}

model User {
    id           String        @id @default(cuid())
    email        String        @unique
    nom          String
    password     String
    role         Role          @default(RECEPTIONNISTE)
    active       Boolean       @default(true)
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    reservations Reservation[]
    paiements    Paiement[]
    recus        Recu[]
    actionLogs   ActionLog[]

    @@index([email])
}

enum TypeChambre {
    SIMPLE
    DOUBLE
    SUITE
}

enum StatutChambre {
    LIBRE
    OCCUPE
}

model Chambre {
    id               String        @id @default(cuid())
    numero           String        @unique
    type             TypeChambre
    tarif            Decimal
    statut           StatutChambre  @default(LIBRE)
    caracteristiques String[]
    createdAt        DateTime      @default(now())
    updatedAt        DateTime      @updatedAt
    reservations     Reservation[]

    @@index([numero])
}

enum StatutReservation {
    CONFIRMEE
    EN_COURS
    TERMINEE
    ANNULEE
}

model Reservation {
    id              String             @id @default(cuid())
    clientNom       String
    clientTelephone String
    chambreId       String
    chambre         Chambre            @relation(fields: [chambreId], references: [id])
    clientId        String?
    client          Client?            @relation(fields: [clientId], references: [id])
    dateArrivee     DateTime
    dateDepart      DateTime
    prixTotal       Decimal
    statut          StatutReservation  @default(CONFIRMEE)
    notes           String?
    createdAt       DateTime           @default(now())
    updatedAt       DateTime           @updatedAt
    createdById     String
    createdBy       User               @relation(fields: [createdById], references: [id])
    paiements       Paiement[]
    recus           Recu[]

    @@index([chambreId])
    @@index([clientId])
    @@index([createdById])
    @@index([dateArrivee])
    @@index([dateDepart])
    @@index([statut])
}

model Client {
    id           String        @id @default(cuid())
    nom          String
    telephone    String        @unique
    email        String?
    notes        String?
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    reservations Reservation[]

    @@index([telephone])
    @@index([nom])
}

enum ModePaiement {
    ESPECES
    MOBILE_MONEY
}

model Paiement {
    id            String        @id @default(cuid())
    montant       Decimal
    mode          ModePaiement
    estAcompte    Boolean       @default(false)
    reference     String?
    reservationId String
    reservation   Reservation   @relation(fields: [reservationId], references: [id])
    createdById   String
    createdBy     User          @relation(fields: [createdById], references: [id])
    createdAt     DateTime      @default(now())

    @@index([reservationId])
    @@index([createdById])
    @@index([createdAt])
}

model Recu {
    id            String      @id @default(cuid())
    numero        Int         @unique @default(autoincrement())
    reservationId String
    reservation   Reservation @relation(fields: [reservationId], references: [id])
    montant       Decimal
    estDuplicate  Boolean     @default(false)
    createdById   String
    createdBy     User        @relation(fields: [createdById], references: [id])
    createdAt     DateTime    @default(now())

    @@index([reservationId])
    @@index([numero])
}

model ConfigHotel {
    id        String   @id @default(cuid())
    nom       String   @default("Hotel")
    adresse   String   @default("")
    telephone String   @default("")
    email     String   @default("")
    updatedAt DateTime @updatedAt
}

enum TypeAction {
    CREATION
    MODIFICATION
    SUPPRESSION
    CONNEXION
    DECONNEXION
    ANNULATION
}

model ActionLog {
    id        String     @id @default(cuid())
    userId    String
    user      User       @relation(fields: [userId], references: [id])
    action    TypeAction
    entite    String
    entiteId  String?
    details   Json?
    createdAt DateTime   @default(now())

    @@index([userId])
    @@index([action])
    @@index([entite])
    @@index([createdAt])
}
