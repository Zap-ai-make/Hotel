// Hotel Management System - Schema Prisma
// Base de donnees: Neon PostgreSQL

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    RECEPTIONNISTE
    MANAGER
    ADMIN
}

model User {
    id           String        @id @default(cuid())
    email        String        @unique
    nom          String
    password     String
    role         Role          @default(RECEPTIONNISTE)
    active       Boolean       @default(true)
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    reservations Reservation[]

    @@index([email])
}

enum TypeChambre {
    SIMPLE
    DOUBLE
    SUITE
}

enum StatutChambre {
    LIBRE
    OCCUPE
}

model Chambre {
    id               String        @id @default(cuid())
    numero           String        @unique
    type             TypeChambre
    tarif            Decimal
    statut           StatutChambre  @default(LIBRE)
    caracteristiques String[]
    createdAt        DateTime      @default(now())
    updatedAt        DateTime      @updatedAt
    reservations     Reservation[]

    @@index([numero])
}

enum StatutReservation {
    CONFIRMEE
    EN_COURS
    TERMINEE
    ANNULEE
}

model Reservation {
    id              String             @id @default(cuid())
    clientNom       String
    clientTelephone String
    chambreId       String
    chambre         Chambre            @relation(fields: [chambreId], references: [id])
    dateArrivee     DateTime
    dateDepart      DateTime
    prixTotal       Decimal
    statut          StatutReservation  @default(CONFIRMEE)
    notes           String?
    createdAt       DateTime           @default(now())
    updatedAt       DateTime           @updatedAt
    createdById     String
    createdBy       User               @relation(fields: [createdById], references: [id])

    @@index([chambreId])
    @@index([createdById])
    @@index([dateArrivee])
    @@index([dateDepart])
    @@index([statut])
}
