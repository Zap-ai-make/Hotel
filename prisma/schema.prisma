// Hotel Management System - Schema Prisma
// Base de donnees: Neon PostgreSQL

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    RECEPTIONNISTE
    MANAGER
    ADMIN
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    nom       String
    password  String
    role      Role     @default(RECEPTIONNISTE)
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([email])
}

enum TypeChambre {
    SIMPLE
    DOUBLE
    SUITE
}

enum StatutChambre {
    LIBRE
    OCCUPE
}

model Chambre {
    id               String        @id @default(cuid())
    numero           String        @unique
    type             TypeChambre
    tarif            Decimal
    statut           StatutChambre  @default(LIBRE)
    caracteristiques String[]
    createdAt        DateTime      @default(now())
    updatedAt        DateTime      @updatedAt

    @@index([numero])
}
